#!/bin/bash

# Pre-commit hook
# Automatically catches unused code and linting issues before commits
# Bypass with: git commit --no-verify

set -e

echo "Running pre-commit checks..."

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Track if any check fails
CHECKS_FAILED=0

# Function to print colored output
print_error() {
    echo -e "${RED}x $1${NC}"
}

print_success() {
    echo -e "${GREEN}✓ $1${NC}"
}

print_warning() {
    echo -e "${YELLOW}! $1${NC}"
}

print_info() {
    echo "i $1"
}

# Get list of staged TypeScript/JavaScript files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|tsx|js|jsx)$' || true)

if [ -z "$STAGED_FILES" ]; then
    print_info "No TypeScript/JavaScript files staged, skipping checks"
    exit 0
fi

print_info "Checking $(echo "$STAGED_FILES" | wc -l | xargs) staged files..."
echo ""

# Check 1: Architecture hierarchy (BLOCKS commit on violations)
echo "1/6  Checking architecture hierarchy..."
if ./scripts/check-architecture.sh --staged > /tmp/arch-output.txt 2>&1; then
    print_success "Architecture hierarchy check passed"
else
    print_error "Architecture hierarchy violations found"
    echo ""
    grep -v "^Checking\|^---\|^$\|Required\|Pages can\|API routes\|Services can" /tmp/arch-output.txt | head -10 | sed 's/^/    /'
    echo ""
    print_info "See docs/refactoring/architecture-violations.md for fix plan"
    CHECKS_FAILED=1
fi

echo ""

# Check 2: Schema location (BLOCKS commit on violations)
echo "2/6  Checking schema locations..."
if ./scripts/check-schemas.sh --staged > /tmp/schema-output.txt 2>&1; then
    print_success "Schema location check passed"
else
    print_error "Inline schema violations found"
    echo ""
    grep -v "^Checking\|^---\|^$\|API routes\|Instead\|Defined in\|Imported using\|See:" /tmp/schema-output.txt | head -10 | sed 's/^/    /'
    echo ""
    print_info "See docs/TODO-schema-extraction.md for schema organization"
    CHECKS_FAILED=1
fi

echo ""

# Check 3: Deep architecture (repository purity, HOF pattern, auth) - BLOCKS on errors
echo "3/6  Running deep architecture checks..."
if ./scripts/check-deep-architecture.sh > /tmp/deep-arch-output.txt 2>&1; then
    print_success "Deep architecture check passed"
else
    # Check if it's just warnings or actual errors
    if grep -q "error(s)" /tmp/deep-arch-output.txt; then
        print_error "Deep architecture violations found"
        echo ""
        grep -E "^(✗|  -)" /tmp/deep-arch-output.txt | head -10 | sed 's/^/    /'
        echo ""
        CHECKS_FAILED=1
    else
        print_success "Deep architecture check passed"
        print_warning "Note: Some warnings found (not blocking)"
    fi
fi

echo ""

# Check 4: TypeScript type checking (includes unused code detection)
echo "4/6  Running TypeScript type checking..."
bun run type-check --silent 2>&1 | tee /tmp/tsc-output.txt > /dev/null

# Check for errors in production code (src/) only
PROD_ERRORS=$(grep -E "^src/.*(error TS)" /tmp/tsc-output.txt || true)

if [ -n "$PROD_ERRORS" ]; then
    print_error "TypeScript errors found in production code"
    echo ""
    echo "   Production code errors:"
    echo "$PROD_ERRORS" | head -15
    echo ""

    # Count unused code errors
    UNUSED_COUNT=$(echo "$PROD_ERRORS" | grep -c "error TS6133\|error TS6196" || true)
    if [ $UNUSED_COUNT -gt 0 ]; then
        print_info "Found $UNUSED_COUNT unused variable/import error(s)"
    fi
    echo ""
    CHECKS_FAILED=1
else
    # Check if there are test errors (informational only)
    TEST_ERRORS=$(grep -E "^tests/.*(error TS)" /tmp/tsc-output.txt || true)
    if [ -n "$TEST_ERRORS" ]; then
        print_success "TypeScript checks passed for production code"
        print_warning "Note: $(echo "$TEST_ERRORS" | wc -l | xargs) error(s) in test files (not blocking)"
    else
        print_success "TypeScript checks passed"
    fi
fi

echo ""

# Check 5: Biome linting (auto-fix then verify)
echo "5/6  Running Biome linter..."

# First, auto-fix any fixable issues (formatting, import ordering)
bunx biome check --write src/ > /tmp/biome-fix.txt 2>&1 || true

# Re-stage any files that were auto-fixed
FIXED_FILES=$(grep "Fixed" /tmp/biome-fix.txt | wc -l | xargs)
if [ "$FIXED_FILES" -gt 0 ]; then
    print_info "Auto-fixed $FIXED_FILES file(s), re-staging..."
    git add -u
fi

# Now run lint check to catch any remaining issues
bun run lint --silent 2>&1 | tee /tmp/biome-output.txt > /dev/null

# Check for unused code errors in production files
BIOME_UNUSED=$(grep -E "src/.*noUnused" /tmp/biome-output.txt || true)

# Check for style errors that should fail the build
# - noUselessConstructor: unnecessary constructors
# - useAwait: async functions without await
BIOME_STYLE_ERRORS=$(grep -E "src/.*(noUselessConstructor|useAwait)" /tmp/biome-output.txt || true)

if [ -n "$BIOME_UNUSED" ]; then
    print_error "Biome found unused code in production files"
    echo ""
    echo "$BIOME_UNUSED" | head -10
    echo ""
    CHECKS_FAILED=1
fi

if [ -n "$BIOME_STYLE_ERRORS" ]; then
    print_error "Biome found style errors in production files"
    echo ""
    echo "   Style issues that must be fixed:"
    echo "$BIOME_STYLE_ERRORS" | head -10
    echo ""
    print_info "Fix these issues:"
    print_info "  - noUselessConstructor: Remove constructor that only calls super()"
    print_info "  - useAwait: Add 'await' or remove 'async' keyword"
    echo ""
    CHECKS_FAILED=1
fi

if [ -z "$BIOME_UNUSED" ] && [ -z "$BIOME_STYLE_ERRORS" ]; then
    # Check for other lint errors (warnings only)
    BIOME_ERRORS=$(grep -E "src/.*lint/" /tmp/biome-output.txt || true)
    if [ -n "$BIOME_ERRORS" ]; then
        print_success "No blocking lint errors detected"
        print_warning "Note: Other lint warnings found (not blocking)"
        echo ""
        print_info "Run 'bun run lint' to see all details"
    else
        print_success "Biome linting passed"
    fi
fi

echo ""

# Check 6: Code quality guardrails (secrets, HTTP_STATUS, file size, imports, TODOs)
echo "6/6  Running code quality checks..."
if ./scripts/check-code-quality.sh --staged > /tmp/quality-output.txt 2>&1; then
    # Check if there were warnings
    if grep -q "warning(s)" /tmp/quality-output.txt; then
        print_success "Code quality check passed"
        print_warning "Note: Some warnings found (not blocking)"
    else
        print_success "Code quality check passed"
    fi
else
    print_error "Code quality violations found"
    echo ""
    grep -E "^(x |    )" /tmp/quality-output.txt | head -10 | sed 's/^/    /'
    echo ""
    CHECKS_FAILED=1
fi

echo ""

# Summary
if [ $CHECKS_FAILED -eq 1 ]; then
    echo "----------------------------------------"
    print_error "Pre-commit checks failed!"
    echo ""
    echo "To fix unused code issues:"
    echo "  1. Remove unused imports and variables"
    echo "  2. Prefix intentionally unused params with '_' (e.g., _request)"
    echo "  3. Run 'bun run type-check' to verify"
    echo ""
    echo "To bypass this hook (not recommended):"
    echo "  git commit --no-verify"
    echo "----------------------------------------"
    exit 1
else
    echo "----------------------------------------"
    print_success "All pre-commit checks passed!"
    echo "----------------------------------------"
    exit 0
fi
