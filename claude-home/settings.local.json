{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "cmd=$(echo \"$TOOL_INPUT\" | jq -r '.command // \"\"'); if [[ \"$cmd\" =~ ^npm\\ |^npm$ ]]; then echo 'Use bun instead of npm' >&2; exit 2; fi"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(done)",
      "Bash(chmod:*)",
      "Bash(git init:*)",
      "Bash(git add:*)",
      "Bash(git branch:*)",
      "Bash(git commit:*)"
    ]
  }
}
